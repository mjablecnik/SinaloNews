# Database (required)
# Connection string for the shared rss-feed PostgreSQL database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rss_feed

# Server
# Port the FastAPI server listens on
APP_PORT=8001

# OpenRouter / LLM (required)
# API key for OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# LLM model to use via OpenRouter (default: cost-effective summarization model)
LLM_MODEL=openai/gpt-4o-mini

# Embedding configuration
# Model name for generating embeddings
EMBEDDING_MODEL=openai/text-embedding-3-small
# Base URL for the OpenAI-compatible embeddings endpoint
EMBEDDING_API_URL=https://openrouter.ai/api/v1
# API key for the embedding endpoint (defaults to OPENROUTER_API_KEY if not set)
EMBEDDING_API_KEY=

# Qdrant vector store
# URL for the Qdrant instance
QDRANT_URL=http://localhost:6333
# API key for Qdrant Cloud or secured instance (leave empty for local)
QDRANT_API_KEY=
# Name of the Qdrant collection used to store article chunk embeddings
QDRANT_COLLECTION=article_chunks

# RAG retrieval parameters
# Number of top chunks to retrieve per query
RAG_TOP_K=10
# Maximum number of chunks from the same article in a single retrieval result
RAG_MAX_CHUNKS_PER_ARTICLE=3

# Text chunking parameters
# Target size in characters for each text chunk
CHUNK_SIZE=1000
# Number of characters to overlap between consecutive chunks
CHUNK_OVERLAP=200

# LangSmith observability (optional)
# API key for LangSmith tracing (leave empty to disable tracing)
LANGSMITH_API_KEY=
# LangSmith project name for organizing traces
LANGSMITH_PROJECT=sinalo-agent
# Enable or disable LangSmith tracing ("true" / "false")
LANGSMITH_TRACING=true

# CLI client configuration
# Base URL for the AI agent server (used by scripts/ai-agent.sh)
AI_AGENT_URL=http://localhost:8001
