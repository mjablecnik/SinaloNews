# Required: PostgreSQL connection string (shared with rss-feed service)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Optional: Server port (default: 8002)
APP_PORT=8002

# Optional: LLM model to use via OpenRouter (default: openai/gpt-4o-mini)
LLM_MODEL=openai/gpt-4o-mini

# Optional: Number of articles to process per batch (default: 20)
BATCH_SIZE=20

# Optional: Delay in seconds before retrying after rate limit (default: 5)
LLM_RETRY_DELAY_SECONDS=5

# Optional: Maximum number of LLM retry attempts (default: 3)
LLM_MAX_RETRIES=3

# Optional: LangSmith API key for LLM call tracing
LANGSMITH_API_KEY=ls__your-langsmith-api-key

# Optional: LangSmith project name (default: sinalo-classifier)
LANGSMITH_PROJECT=sinalo-classifier

# Optional: Enable LangSmith tracing (default: true)
LANGSMITH_TRACING=true
