# Required: PostgreSQL connection string (shared with rss-feed service)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Optional: Server port (default: 8002)
APP_PORT=8002

# Optional: LLM model to use via OpenRouter (default: openai/gpt-4o-mini)
LLM_MODEL=openai/gpt-4o-mini

# Optional: Number of articles to process per batch (default: 20)
BATCH_SIZE=20

# Optional: Delay in seconds before retrying after rate limit (default: 5)
LLM_RETRY_DELAY_SECONDS=5

# Optional: Maximum number of LLM retry attempts (default: 3)
LLM_MAX_RETRIES=3

# Optional: LangSmith API key for LLM call tracing
LANGSMITH_API_KEY=ls__your-langsmith-api-key

# Optional: LangSmith project name (default: sinalo-classifier)
LANGSMITH_PROJECT=sinalo-classifier

# Optional: Enable LangSmith tracing (default: true)
LANGSMITH_TRACING=true

# Optional: LLM model to use for grouping (default: same as LLM_MODEL)
# GROUPING_LLM_MODEL=openai/gpt-4o-mini

# Optional: Minimum number of articles in a category required to trigger grouping (default: 2)
GROUPING_MIN_ARTICLES=2

# Optional: Maximum number of articles per category sent to clustering LLM call (default: 50)
GROUPING_MAX_ARTICLES_PER_CATEGORY=50

# Optional: Minimum importance score for articles to be considered for grouping (default: 0 = all)
GROUPING_MIN_SCORE=0

# Optional: Similarity threshold for RAG-based grouping (0.0-1.0, default: 0.75)
GROUPING_SIMILARITY_THRESHOLD=0.75

# Qdrant Configuration
# Optional: Qdrant server URL (default: http://localhost:6333)
QDRANT_URL=http://localhost:6333

# Optional: Qdrant API key for authentication
QDRANT_API_KEY=your-qdrant-api-key

# Optional: Qdrant collection name for full article embeddings (default: article_full)
QDRANT_FULL_ARTICLE_COLLECTION=article_full

# Embedding Configuration
# Optional: Embedding model to use via OpenRouter (default: openai/text-embedding-3-small)
EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional: Embedding API URL (default: https://openrouter.ai/api/v1)
EMBEDDING_API_URL=https://openrouter.ai/api/v1
